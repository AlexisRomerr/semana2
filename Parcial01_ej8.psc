Algoritmo Parcial01_ej8
	
	Definir num Como Entero
	Definir positiv Como Logico
	
	
	Escribir "Ingrese un numero positivo y menor que 100"
	Leer num
	
	Si num > 0 y num < 100 Entonces
		positiv = Verdadero 
		Escribir "El valor es ", positiv
		
	SiNo
		Positiv = Falso	
		Escribir "Su valor es ", positiv
	
	FinSi
	

FinAlgoritmo
