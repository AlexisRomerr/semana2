Algoritmo Parcial01_ej6
	
	Definir num1, num2, suma, resta Como Entero
	
	Escribir "Ingrese un numero para sumar y restar"
	Leer num1
	
	Escribir "Ingrese otro numero para sumar y restar"
	Leer num2
	
	suma = num1 + num2
	Escribir "La suma de sus numeros es: ", suma 
	
	resta = num1 - num2
	Escribir "La resta de sus numeros es: ", resta
	
FinAlgoritmo
