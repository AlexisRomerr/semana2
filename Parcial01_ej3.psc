Algoritmo Parcial01_ej3
	
	Definir num Como Entero
	
	Escribir "Ingrese un numero del 1 al 7 para saber el dia de la semana"
	Leer num
	
	Segun num Hacer 
		1:
			Escribir "Es domingo"
	    2:
			Escribir "Es lunes"
		3:
			Escribir "Es martes"
		4:
			Escribir "Es miercoles"
		 5:
			Escribir "Es jueves"
		 6: 
			Escribir "Es viernes"
		 7:
			Escribir "Es sabado"
		De Otro Modo:
			Escribir "Solo existen 7 dias en la semana"
	FinSegun
	
FinAlgoritmo
